
# 忽略所有在 samples/ 目录下的内容
samples/

# ============ 推荐添加的通用规则 ============

# Python 自动生成的缓存和字节码文件
__pycache__/
*.pyc
*.pyo
*.pyd

# 常见的虚拟环境文件夹
venv/
.venv/
env/

# IDE 和编辑器的配置文件
.idea/
.vscode/

# 通常不追踪的日志、数据或输出文件夹
logs/
output/
results/
data/
datasets/

# 模型权重文件 (如果很大，推荐使用 Git LFS)
*.pth
*.pt
*.h5

